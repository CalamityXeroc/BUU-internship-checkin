<!--pages/admin-dashboard/admin-dashboard.wxml-->
<view class="dashboard-page">
  <!-- 顶部统计 -->
  <view class="dash-header" style="padding-top:{{headerPaddingTop}}px;">
    <view class="dash-title-row" style="height:{{capsuleHeight}}px;">
      <view class="dash-title">管理后台</view>
      <view class="header-actions" style="height:{{capsuleHeight}}px;">
        <view class="icon-btn" bindtap="goSettings">⚙️</view>
        <view class="icon-btn" bindtap="handleLogout">🚪</view>
      </view>
    </view>

    <view class="stats-row">
      <view class="stat-card">
        <view class="stat-num">{{totalStudents}}</view>
        <view class="stat-label">学生总数</view>
      </view>
      <view class="stat-card">
        <view class="stat-num">{{todaySignCount}}</view>
        <view class="stat-label">今日签到</view>
      </view>
      <view class="stat-card">
        <view class="stat-num">{{totalSignCount}}</view>
        <view class="stat-label">总签到次数</view>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索学生姓名或学号..." value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="handleSearch"/>
    <view class="search-btn" bindtap="handleSearch">搜索</view>
  </view>

  <!-- 绑定状态筛选 -->
  <view class="filter-tabs">
    <view class="filter-tab {{bindStatus === '' ? 'active' : ''}}" data-status="" bindtap="onBindFilter">全部</view>
    <view class="filter-tab {{bindStatus === 'bound' ? 'active' : ''}}" data-status="bound" bindtap="onBindFilter">已绑定</view>
    <view class="filter-tab {{bindStatus === 'unbound' ? 'active' : ''}}" data-status="unbound" bindtap="onBindFilter">未绑定</view>
  </view>

  <!-- 添加/编辑表单 -->
  <view class="student-form" wx:if="{{showForm}}">
    <view class="form-card">
      <view class="form-card-title">{{formMode === 'add' ? '添加学生' : '编辑学生'}}</view>
      <view class="form-row">
        <view class="form-label">学号</view>
        <input class="form-input" placeholder="请输入学号" value="{{formSid}}" bindinput="onFormSidInput"/>
      </view>
      <view class="form-row">
        <view class="form-label">姓名</view>
        <input class="form-input" placeholder="请输入姓名" value="{{formName}}" bindinput="onFormNameInput"/>
      </view>
      <view class="form-btns">
        <view class="form-btn cancel" bindtap="hideForm">取消</view>
        <view class="form-btn confirm" bindtap="submitForm">{{formMode === 'add' ? '添加' : '保存'}}</view>
      </view>
    </view>
  </view>

  <!-- 学生列表 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">学生列表</view>
      <view class="section-add" bindtap="showAddForm">+ 添加</view>
    </view>

    <view class="student-list" wx:if="{{students.length > 0}}">
      <view class="student-item" wx:for="{{students}}" wx:key="_id" data-sid="{{item.sid}}" data-name="{{item.name}}" data-id="{{item._id}}" bindtap="onStudentTap">
        <view class="student-avatar">👤</view>
        <view class="student-info">
          <view class="student-name">{{item.name}}</view>
          <view class="student-sid">{{item.sid}}</view>
        </view>
        <view class="student-status">
          <view class="tag {{item.openid ? 'tag-success' : 'tag-warning'}}">
            {{item.openid ? '已绑定' : '未绑定'}}
          </view>
        </view>
        <view class="student-arrow">→</view>
      </view>
    </view>

    <view class="empty-state" wx:else>
      <view class="icon">📭</view>
      <view class="title">暂无学生数据</view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMoreStudents">
      {{loading ? '加载中...' : '加载更多'}}
    </view>
    <view class="load-end" wx:if="{{!hasMore && students.length > 0}}">
      — 已加载全部 {{totalStudents}} 名学生 —
    </view>
  </view>
</view>
