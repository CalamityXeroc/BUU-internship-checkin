/* pages/admin-records/admin-records.wxss */
.records-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* ===== 顶部 ===== */
.page-top {
  background: #fff;
  padding: 32rpx;
  border-bottom: 1rpx solid #E8E8E8;
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: #666666;
}

/* ===== 工具栏 ===== */
.toolbar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
}

.tool-btn {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #333333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tool-btn.active {
  background: #E6F7FF;
  color: #1890FF;
}

/* ===== 筛选面板 ===== */
.filter-panel {
  background: #fff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.filter-label {
  width: 80rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
}

.filter-picker-wrap {
  flex: 1;
}

.filter-input, .filter-picker {
  flex: 1;
  height: 72rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333333;
  display: flex;
  align-items: center;
}

.filter-picker {
  color: #666666;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 16rpx;
}

/* ===== 记录列表 ===== */
.record-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  background: #fff;
  border-radius: 14rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.record-sid {
  font-size: 24rpx;
  color: #666666;
}

.record-time-badge {
  background: #E6F7FF;
  color: #1890FF;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  font-family: monospace;
}

.record-location {
  font-size: 24rpx;
  color: #666666;
}

/* ===== 加载 ===== */
.load-more, .load-end {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
}

.load-more {
  color: #1890FF;
}

.load-end {
  color: #999999;
}
