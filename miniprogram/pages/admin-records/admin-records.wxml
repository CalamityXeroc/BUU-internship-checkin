<!--pages/admin-records/admin-records.wxml-->
<view class="records-page">
  <!-- 顶部标题 -->
  <view class="page-top">
    <view class="page-title">
      {{filterName ? filterName + ' 的签到记录' : '签到记录'}}
    </view>
    <view class="page-subtitle">共 {{total}} 条记录</view>
  </view>

  <!-- 工具栏 -->
  <view class="toolbar">
    <view class="tool-btn {{showFilter ? 'active' : ''}}" bindtap="toggleFilter">
      🔍 筛选
    </view>
    <view class="tool-btn" bindtap="handleExport">
      {{exporting ? '导出中...' : '📥 导出'}}
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{showFilter}}">
    <view class="filter-row">
      <view class="filter-label">学号/姓名</view>
      <input class="filter-input" placeholder="输入学号或姓名" value="{{filterKeyword}}" bindinput="onKeywordInput"/>
    </view>
    <view class="filter-row">
      <view class="filter-label">日期</view>
      <picker class="filter-picker-wrap" mode="date" value="{{filterDate}}" bindchange="onDateChange">
        <view class="filter-picker">
          {{filterDate || '选择日期'}}
        </view>
      </picker>
    </view>
    <view class="filter-actions">
      <button class="btn-sm btn-outline" bindtap="clearFilter">清除</button>
      <button class="btn-sm btn-primary" style="width:auto;font-size:24rpx;padding:12rpx 32rpx;" bindtap="applyFilter">应用筛选</button>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="record-list" wx:if="{{records.length > 0}}">
    <view class="record-item" wx:for="{{records}}" wx:key="_id">
      <view class="record-top">
        <view class="record-student">
          <view class="record-name">{{item.name}}</view>
          <view class="record-sid">{{item.sid}}</view>
        </view>
        <view class="record-time-badge">{{formatTime(item.signTime)}}</view>
      </view>
      <view class="record-location">📍 {{item.location}}</view>
    </view>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}" bindtap="loadMore">
    {{loading ? '加载中...' : '加载更多'}}
  </view>

  <view class="load-end" wx:if="{{!hasMore && records.length > 0}}">
    — 已加载全部记录 —
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{records.length === 0 && !loading}}">
    <view class="icon">📭</view>
    <view class="title">暂无签到记录</view>
  </view>
</view>
