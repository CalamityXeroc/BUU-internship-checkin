<!--pages/admin-settings/admin-settings.wxml-->
<view class="settings-page">
  <view class="settings-card">
    <view class="card-title">修改密码</view>

    <view class="form-group">
      <view class="form-label">原密码</view>
      <input class="form-input" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPwdInput" type="password" password/>
    </view>

    <view class="form-group">
      <view class="form-label">新密码</view>
      <input class="form-input" placeholder="请输入新密码（至少4位）" value="{{newPassword}}" bindinput="onNewPwdInput" type="password" password/>
    </view>

    <view class="form-group">
      <view class="form-label">确认新密码</view>
      <input class="form-input" placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onConfirmPwdInput" type="password" password/>
    </view>

    <view class="success-msg" wx:if="{{successMsg}}">{{successMsg}}</view>
    <view class="error-msg" wx:if="{{errorMsg}}">{{errorMsg}}</view>

    <button class="btn-primary" bindtap="handleChangePassword" loading="{{loading}}" disabled="{{loading}}">
      确认修改
    </button>

    <view class="back-link" bindtap="goBack">← 返回</view>
  </view>

</view>
