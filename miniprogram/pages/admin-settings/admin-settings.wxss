/* pages/admin-settings/admin-settings.wxss */
.settings-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
}

.settings-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 28rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.success-msg {
  background: #F6FFED;
  color: #52C41A;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.error-msg {
  background: #FFF2F0;
  color: #FF4D4F;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.back-link {
  text-align: center;
  margin-top: 24rpx;
  color: #666666;
  font-size: 26rpx;
}

/* ===== 初始化 ===== */
.init-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.init-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.mt-2 {
  margin-top: 16rpx;
}
