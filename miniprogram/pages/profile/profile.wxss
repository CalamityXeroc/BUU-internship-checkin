/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* ===== 头部 ===== */
.profile-header {
  background: linear-gradient(135deg, #1890FF, #40A9FF);
  padding: 64rpx 32rpx 48rpx;
  text-align: center;
  border-radius: 0 0 32rpx 32rpx;
}

.profile-avatar {
  font-size: 96rpx;
  background: rgba(255, 255, 255, 0.2);
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}

.profile-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.profile-sid {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 信息卡片 ===== */
.info-section {
  padding: 24rpx;
  margin-top: 24rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.info-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-item.no-border {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

/* ===== 退出登录 ===== */
.logout-section {
  padding: 24rpx;
  margin-top: 48rpx;
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #FF4D4F;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #FFF2F0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.logout-btn::after {
  border: none;
}

.version-text {
  text-align: center;
  color: #999999;
  font-size: 22rpx;
  margin-top: 24rpx;
}
