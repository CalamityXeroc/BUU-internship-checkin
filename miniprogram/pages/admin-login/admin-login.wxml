<!--pages/admin-login/admin-login.wxml-->
<view class="admin-login-page">
  <view class="login-card">
    <view class="login-header">
      <view class="login-icon">👨‍🏫</view>
      <view class="login-title">教师登录</view>
      <view class="login-subtitle">使用账号密码登录管理系统</view>
    </view>

    <view class="form-section">
      <view class="form-group">
        <view class="form-label">账号</view>
        <input class="form-input" placeholder="请输入账号" value="{{account}}" bindinput="onAccountInput" type="text"/>
      </view>

      <view class="form-group">
        <view class="form-label">密码</view>
        <input class="form-input" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" type="password" password/>
      </view>

      <view class="error-msg" wx:if="{{errorMsg}}">{{errorMsg}}</view>

      <button class="btn-primary mt-4" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
        登 录
      </button>

      <view class="back-link" bindtap="goBack">← 返回首页</view>
    </view>
  </view>

  <!-- 返回首页 -->
  <view class="home-return" bindtap="goHome">
    <view class="home-return-icon">🏠</view>
    <view class="home-return-text">返回首页</view>
  </view>
</view>
