/* pages/login/login.wxss */
.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1890FF 0%, #40A9FF 60%, #91D5FF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
  gap: 32rpx;
}

.login-card {
  width: 100%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

.login-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.login-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.login-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 12rpx;
}

.login-subtitle {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

/* 微信登录按钮 */
.wechat-btn {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.wechat-icon {
  font-size: 40rpx;
}

.wechat-btn::after {
  border: none;
}

/* 表单 */
.form-section {
  width: 100%;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

/* 错误提示 */
.error-msg {
  background: #FFF2F0;
  color: #FF4D4F;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

/* 底部链接 */
.login-footer {
  text-align: center;
  margin-top: 36rpx;
}

.footer-link {
  color: #1890FF;
  font-size: 26rpx;
  font-weight: 500;
}

.back-link {
  text-align: center;
  margin-top: 24rpx;
  color: #666666;
  font-size: 26rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

/* ===== 返回首页按钮 ===== */
.home-return {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx 48rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 48rpx;
  transition: all 0.2s;
}

.home-return:active {
  background: rgba(255, 255, 255, 0.25);
  transform: scale(0.97);
}

.home-return-icon {
  font-size: 32rpx;
}

.home-return-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  letter-spacing: 2rpx;
}
