/* pages/index/index.wxss */
.entry-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1890FF 0%, #40A9FF 60%, #91D5FF 100%);
  display: flex;
  flex-direction: column;
}

.loading-screen {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.loading-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 24rpx;
}

.entry-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 80rpx 40rpx 60rpx;
}

.header-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.header-section .logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.header-section .app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 4rpx;
}

.role-cards {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.role-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.role-card:active {
  transform: scale(0.97);
}

.role-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.role-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.role-arrow {
  text-align: right;
  font-size: 26rpx;
  color: #1890FF;
  font-weight: 600;
  margin-top: 16rpx;
}

.footer-note {
  text-align: center;
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
  margin-top: 40rpx;
}
